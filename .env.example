ROOT_DOMAIN=
LAB_DOMAIN=
HEADSCALE_DOMAIN=
TAILNET_DOMAIN=

ADMIN_EMAIL=

CF_DNS_API_TOKEN=

# Known after CDK deploy:
VPS_PUBLIC_IP=

# Filled in after bring-up sequence step 2:
INFRA_AUTHKEY=

# Filled in after bring-up sequence step 6 (docker exec ts-infra tailscale ip -4):
VPS_TAILNET_IP=

GF_ADMIN_PASSWORD=

# SMTP — used by Watchtower (update notifications) and Alertmanager (alerts)
SMTP_HOST=
SMTP_PORT=587
SMTP_FROM=
SMTP_USERNAME=
SMTP_PASSWORD=
ALERT_EMAIL=

GOOGLE_OIDC_CLIENT_ID=
GOOGLE_OIDC_CLIENT_SECRET=
# Comma-separated list of allowed Google accounts (e.g. alice@gmail.com,bob@gmail.com):
GOOGLE_OIDC_ALLOWED_USERS=
