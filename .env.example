ROOT_DOMAIN=
LAB_DOMAIN=
HEADSCALE_DOMAIN=
TAILNET_DOMAIN=

ADMIN_EMAIL=

CF_DNS_API_TOKEN=

# Known after CDK deploy:
VPS_PUBLIC_IP=

# Filled in after bring-up sequence step 2:
INFRA_AUTHKEY=

# Filled in after bring-up sequence step 6 (docker exec ts-infra tailscale ip -4):
VPS_TAILNET_IP=

GF_ADMIN_PASSWORD=

# Authentik OIDC client credentials for grafana.lab.gn.al (Slice E of the
# Authentik plan). Same client_id/secret as kaiser Grafana — one Authentik
# OAuth2 provider serves both, with two redirect URIs. Produced by
# ~/dev/cn-authentik/setup-grafana-oidc.sh on infra.lan first-run.
AUTHENTIK_GRAFANA_CLIENT_ID=
AUTHENTIK_GRAFANA_CLIENT_SECRET=

# SMTP — used by Watchtower (update notifications) and Alertmanager (alerts)
SMTP_HOST=
SMTP_PORT=587
SMTP_FROM=
SMTP_USERNAME=
SMTP_PASSWORD=
ALERT_EMAIL=

GOOGLE_OIDC_CLIENT_ID=
GOOGLE_OIDC_CLIENT_SECRET=
# Comma-separated list of allowed Google accounts (e.g. alice@gmail.com,bob@gmail.com):
GOOGLE_OIDC_ALLOWED_USERS=

# Longhorn UI basic auth — used by glance monitor widget so the Longhorn
# status check returns 200 instead of 401. Match the htpasswd entry in
# the amun-longhorn sealed Secret (cluster-side).
LONGHORN_USER=
LONGHORN_PASS=

# Raidnas SNMPv2c community — set this value in DSM Control Panel →
# Terminal & SNMP, then mirror it here. snmp_exporter does not honor
# env var interpolation in its config; setup.sh envsubst-renders
# tailnet/snmp-exporter/snmp.yml.tmpl → snmp.yml so the community is
# baked in at deploy time. Set to a high-entropy string; treat as a
# secret (LAN-perimeter exposed, but still credentials).
SNMP_RAIDNAS_COMMUNITY=
