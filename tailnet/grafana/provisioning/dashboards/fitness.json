    {
      "id": 21,
      "type": "stat",
      "title": "pg_up",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 21,
        "w": 4,
        "h": 4
