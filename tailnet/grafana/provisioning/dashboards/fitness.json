      },
      "gridPos": {
        "x": 0,
        "y": 29,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "A",
          "expr": "sum(rate(pg_stat_database_tup_fetched{datname=\"sparkyfitness\"}[5m]))",
