        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "B",
          "expr": "sum(rate(pg_stat_database_tup_returned{datname=\"sparkyfitness\"}[5m]))",
          "legendFormat": "returned"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "C",
          "expr": "sum(rate(pg_stat_database_tup_inserted{datname=\"sparkyfitness\"}[5m]))",
          "legendFormat": "inserted"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "D",
          "expr": "sum(rate(pg_stat_database_tup_updated{datname=\"sparkyfitness\"}[5m]))",
          "legendFormat": "updated"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "refId": "E",
          "expr": "sum(rate(pg_stat_database_tup_deleted{datname=\"sparkyfitness\"}[5m]))",
          "legendFormat": "deleted"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10
          }
        },
