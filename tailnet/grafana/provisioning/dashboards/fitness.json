    {
      "id": 30,
      "type": "row",
      "title": "Logs (last 1h)",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 37,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 31,
      "type": "logs",
      "title": "All cn-fitness logs",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "x": 0,
        "y": 38,
        "w": 24,
        "h": 10
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "refId": "A",
          "expr": "{stack=\"cn-fitness\"}"
        }
      ],
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      }
    },
    {
      "id": 32,
      "type": "logs",
      "title": "Errors / warnings only",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "x": 0,
        "y": 48,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "refId": "A",
          "expr": "{stack=\"cn-fitness\"} |~ \"(?i)(error|panic|fatal|warn)\""
        }
      ],
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      }
    }
  ]
}