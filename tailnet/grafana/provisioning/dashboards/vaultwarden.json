{
  "uid": "vaultwarden",
  "title": "Vaultwarden",
  "tags": ["vaultwarden", "homelab"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": false,
      "keepTime": true,
      "tags": ["homelab"],
      "targetBlank": false,
      "title": "Dashboards",
      "tooltip": "",
      "type": "dashboards",
      "url": ""
    }
  ],
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "At a glance",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Backup health (30 days)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "x": 0, "y": 1, "w": 24, "h": 5 },
      "targets": [
        {
          "expr": "sum(count_over_time({container=\"cn-vaultwarden-backup-1\"} |= \"Uploaded\" |= \"S3\" [30d]))",
          "refId": "A",
          "queryType": "instant",
          "legendFormat": "S3 uploads (30d)"
        },
        {
          "expr": "sum(count_over_time({container=\"cn-vaultwarden-backup-1\"} |= \"Uploaded\" |= \"WebDAV\" [30d]))",
          "refId": "B",
          "queryType": "instant",
          "legendFormat": "WebDAV uploads (30d)"
        },
        {
          "expr": "sum(count_over_time({container=\"cn-vaultwarden-backup-1\"} |= \"level=ERROR\" [30d]))",
          "refId": "C",
          "queryType": "instant",
          "legendFormat": "errors (30d)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value #A" },
            "properties": [
              { "id": "displayName", "value": "S3 uploads" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #B" },
            "properties": [
              { "id": "displayName", "value": "WebDAV uploads" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #C" },
            "properties": [
              { "id": "displayName", "value": "Errors" },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } },
              { "id": "color", "value": { "mode": "thresholds" } }
            ]
          }
        ]
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      }
    },
    {
      "id": 4,
      "type": "row",
      "title": "Host (passwords.lan)",
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 5,
      "type": "gauge",
      "title": "CPU usage",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 7, "w": 6, "h": 6 },
      "targets": [
        { "expr": "(1 - avg by (instance)(rate(node_cpu_seconds_total{instance=\"vault.ts.gn.al:9100\",mode=\"idle\"}[5m]))) * 100", "refId": "A", "legendFormat": "CPU" }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 100, "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdMarkers": true
      }
    },
    {
      "id": 6,
      "type": "gauge",
      "title": "Memory usage",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 6, "y": 7, "w": 6, "h": 6 },
      "targets": [
        { "expr": "(1 - node_memory_MemAvailable_bytes{instance=\"vault.ts.gn.al:9100\"} / node_memory_MemTotal_bytes{instance=\"vault.ts.gn.al:9100\"}) * 100", "refId": "A", "legendFormat": "Memory" }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 100, "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 85 }]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdMarkers": true
      }
    },
    {
      "id": 7,
      "type": "gauge",
      "title": "Disk usage (/)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 7, "w": 6, "h": 6 },
      "targets": [
        { "expr": "(1 - node_filesystem_avail_bytes{instance=\"vault.ts.gn.al:9100\",mountpoint=\"/\"} / node_filesystem_size_bytes{instance=\"vault.ts.gn.al:9100\",mountpoint=\"/\"}) * 100", "refId": "A", "legendFormat": "/" }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 100, "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 85 }]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdMarkers": true
      }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Load average",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 18, "y": 7, "w": 6, "h": 6 },
      "targets": [
        { "expr": "node_load1{instance=\"vault.ts.gn.al:9100\"}",  "refId": "A", "legendFormat": "1m" },
        { "expr": "node_load5{instance=\"vault.ts.gn.al:9100\"}",  "refId": "B", "legendFormat": "5m" },
        { "expr": "node_load15{instance=\"vault.ts.gn.al:9100\"}", "refId": "C", "legendFormat": "15m" }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 2 }, { "color": "red", "value": 4 }]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Network throughput",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 13, "w": 12, "h": 8 },
      "targets": [
        { "expr": "rate(node_network_receive_bytes_total{instance=\"vault.ts.gn.al:9100\",device!~\"lo|docker.*|veth.*|br-.*|tailscale.*\"}[5m]) * 8", "refId": "A", "legendFormat": "rx {{device}}" },
        { "expr": "rate(node_network_transmit_bytes_total{instance=\"vault.ts.gn.al:9100\",device!~\"lo|docker.*|veth.*|br-.*|tailscale.*\"}[5m]) * 8", "refId": "B", "legendFormat": "tx {{device}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Disk I/O",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 13, "w": 12, "h": 8 },
      "targets": [
        { "expr": "rate(node_disk_read_bytes_total{instance=\"vault.ts.gn.al:9100\",device!~\"loop.*|dm-.*\"}[5m])", "refId": "A", "legendFormat": "read {{device}}" },
        { "expr": "rate(node_disk_written_bytes_total{instance=\"vault.ts.gn.al:9100\",device!~\"loop.*|dm-.*\"}[5m])", "refId": "B", "legendFormat": "write {{device}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "id": 11,
      "type": "row",
      "title": "Vaultwarden traffic (via VPS Traefik)",
      "gridPos": { "x": 0, "y": 21, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Requests/sec by HTTP code",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by (code)(rate(traefik_service_requests_total{service=\"vaultwarden@consulcatalog\"}[5m]))", "refId": "A", "legendFormat": "{{code}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 30, "stacking": { "mode": "normal" }, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Request latency (p50, p95, p99)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 22, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le)(rate(traefik_service_request_duration_seconds_bucket{service=\"vaultwarden@consulcatalog\"}[5m])))", "refId": "A", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum by (le)(rate(traefik_service_request_duration_seconds_bucket{service=\"vaultwarden@consulcatalog\"}[5m])))", "refId": "B", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum by (le)(rate(traefik_service_request_duration_seconds_bucket{service=\"vaultwarden@consulcatalog\"}[5m])))", "refId": "C", "legendFormat": "p99" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "id": 14,
      "type": "row",
      "title": "Logs",
      "gridPos": { "x": 0, "y": 30, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 15,
      "type": "logs",
      "title": "Vaultwarden (lab) recent logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "x": 0, "y": 31, "w": 24, "h": 10 },
      "targets": [
        { "expr": "{container=\"cn-vaultwarden-vaultwarden-lab-1\"}", "refId": "A" }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    },
    {
      "id": 16,
      "type": "logs",
      "title": "Backup runs (cn-vaultwarden-backup-1)",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "x": 0, "y": 41, "w": 24, "h": 8 },
      "targets": [
        { "expr": "{container=\"cn-vaultwarden-backup-1\"}", "refId": "A" }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    }
  ]
}
