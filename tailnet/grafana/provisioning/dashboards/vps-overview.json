{
  "uid": "vps-overview",
  "title": "VPS Overview",
  "tags": ["vps", "homelab"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": false,
      "keepTime": true,
      "tags": ["homelab"],
      "targetBlank": false,
      "title": "Dashboards",
      "tooltip": "",
      "type": "dashboards",
      "url": ""
    }
  ],
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "At a glance",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Service status (Prometheus targets)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 1, "w": 24, "h": 5 },
      "targets": [
        {
          "expr": "up",
          "refId": "A",
          "legendFormat": "{{job}}",
          "instant": true
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red", "index": 0 },
                "1": { "text": "UP",   "color": "green", "index": 1 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "row",
      "title": "Host (VPS)",
      "gridPos": { "x": 0, "y": 6, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 4,
      "type": "gauge",
      "title": "CPU usage",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 7, "w": 6, "h": 6 },
      "targets": [
        {
          "expr": "(1 - avg by (instance)(rate(node_cpu_seconds_total{instance=\"127.0.0.1:9100\",mode=\"idle\"}[5m]))) * 100",
          "refId": "A",
          "legendFormat": "CPU"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 100, "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 5,
      "type": "gauge",
      "title": "Memory usage",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 6, "y": 7, "w": 6, "h": 6 },
      "targets": [
        {
          "expr": "(1 - node_memory_MemAvailable_bytes{instance=\"127.0.0.1:9100\"} / node_memory_MemTotal_bytes{instance=\"127.0.0.1:9100\"}) * 100",
          "refId": "A",
          "legendFormat": "Memory"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 100, "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdMarkers": true
      }
    },
    {
      "id": 6,
      "type": "gauge",
      "title": "Disk usage (/)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 7, "w": 6, "h": 6 },
      "targets": [
        {
          "expr": "(1 - node_filesystem_avail_bytes{instance=\"127.0.0.1:9100\",mountpoint=\"/\"} / node_filesystem_size_bytes{instance=\"127.0.0.1:9100\",mountpoint=\"/\"}) * 100",
          "refId": "A",
          "legendFormat": "/"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 100, "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdMarkers": true
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Load average",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 18, "y": 7, "w": 6, "h": 6 },
      "targets": [
        { "expr": "node_load1{instance=\"127.0.0.1:9100\"}",  "refId": "A", "legendFormat": "1m" },
        { "expr": "node_load5{instance=\"127.0.0.1:9100\"}",  "refId": "B", "legendFormat": "5m" },
        { "expr": "node_load15{instance=\"127.0.0.1:9100\"}", "refId": "C", "legendFormat": "15m" }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 2 }, { "color": "red", "value": 4 }]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Network throughput",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 13, "w": 12, "h": 8 },
      "targets": [
        { "expr": "rate(node_network_receive_bytes_total{instance=\"127.0.0.1:9100\",device!~\"lo|docker.*|veth.*|br-.*|tailscale.*\"}[5m]) * 8",  "refId": "A", "legendFormat": "rx {{device}}" },
        { "expr": "rate(node_network_transmit_bytes_total{instance=\"127.0.0.1:9100\",device!~\"lo|docker.*|veth.*|br-.*|tailscale.*\"}[5m]) * 8", "refId": "B", "legendFormat": "tx {{device}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Disk I/O",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 13, "w": 12, "h": 8 },
      "targets": [
        { "expr": "rate(node_disk_read_bytes_total{instance=\"127.0.0.1:9100\",device!~\"loop.*|dm-.*\"}[5m])",    "refId": "A", "legendFormat": "read {{device}}" },
        { "expr": "rate(node_disk_written_bytes_total{instance=\"127.0.0.1:9100\",device!~\"loop.*|dm-.*\"}[5m])", "refId": "B", "legendFormat": "write {{device}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "id": 10,
      "type": "row",
      "title": "Headscale",
      "gridPos": { "x": 0, "y": 21, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 11,
      "type": "stat",
      "title": "Tailnet nodes",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 22, "w": 6, "h": 6 },
      "targets": [
        { "expr": "headscale_nodestore_nodes_total", "refId": "A", "legendFormat": "nodes" }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value"
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Headscale map-response rate (poll activity)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 6, "y": 22, "w": 18, "h": 6 },
      "targets": [
        { "expr": "rate(headscale_mapresponse_sent_total[5m])",      "refId": "A", "legendFormat": "sent" },
        { "expr": "rate(headscale_mapresponse_generated_total[5m])", "refId": "B", "legendFormat": "generated" },
        { "expr": "rate(headscale_mapresponse_endpoint_updates_total[5m])", "refId": "C", "legendFormat": "endpoint updates" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "id": 13,
      "type": "row",
      "title": "Traefik",
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Requests/sec by HTTP code",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 29, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by (code)(rate(traefik_entrypoint_requests_total[5m]))", "refId": "A", "legendFormat": "{{code}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 30, "stacking": { "mode": "normal" }, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "p95 request latency by service",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 29, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (service, le)(rate(traefik_service_request_duration_seconds_bucket[5m])))", "refId": "A", "legendFormat": "{{service}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "id": 16,
      "type": "row",
      "title": "Consul",
      "gridPos": { "x": 0, "y": 37, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 17,
      "type": "stat",
      "title": "Consul services (catalog)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 38, "w": 6, "h": 6 },
      "targets": [
        { "expr": "consul_catalog_service_node_healthy", "refId": "A", "legendFormat": "{{service_name}} {{status}}", "instant": true }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      }
    },
    {
      "id": 18,
      "type": "timeseries",
      "title": "Consul critical service-checks (over time)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 6, "y": 38, "w": 18, "h": 6 },
      "targets": [
        { "expr": "sum(consul_health_service_status{status=\"critical\"})", "refId": "A", "legendFormat": "critical" },
        { "expr": "sum(consul_health_service_status{status=\"warning\"})", "refId": "B", "legendFormat": "warning" },
        { "expr": "sum(consul_health_service_status{status=\"passing\"})", "refId": "C", "legendFormat": "passing" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      }
    },
    {
      "id": 19,
      "type": "row",
      "title": "Prometheus & Alertmanager",
      "gridPos": { "x": 0, "y": 44, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 20,
      "type": "stat",
      "title": "Active alerts (firing)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 45, "w": 6, "h": 6 },
      "targets": [
        { "expr": "sum(ALERTS{alertstate=\"firing\"})", "refId": "A", "legendFormat": "firing" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value"
      }
    },
    {
      "id": 21,
      "type": "stat",
      "title": "Targets up / total",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 6, "y": 45, "w": 6, "h": 6 },
      "targets": [
        { "expr": "sum(up)",      "refId": "A", "legendFormat": "up" },
        { "expr": "count(up)",    "refId": "B", "legendFormat": "total" }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      }
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Samples appended/sec",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 45, "w": 12, "h": 6 },
      "targets": [
        { "expr": "rate(prometheus_tsdb_head_samples_appended_total[5m])", "refId": "A", "legendFormat": "samples/s" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false }
      }
    },
    {
      "id": 23,
      "type": "row",
      "title": "Loki",
      "gridPos": { "x": 0, "y": 51, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 24,
      "type": "timeseries",
      "title": "Log lines ingested/sec",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 0, "y": 52, "w": 12, "h": 6 },
      "targets": [
        { "expr": "sum(rate(loki_distributor_lines_received_total[5m]))", "refId": "A", "legendFormat": "lines/s" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "lps",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false }
      }
    },
    {
      "id": 25,
      "type": "timeseries",
      "title": "Bytes ingested/sec",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "x": 12, "y": 52, "w": 12, "h": 6 },
      "targets": [
        { "expr": "sum(rate(loki_distributor_bytes_received_total[5m]))", "refId": "A", "legendFormat": "bytes/s" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": false }
      }
    },
    {
      "id": 26,
      "type": "row",
      "title": "Logs",
      "gridPos": { "x": 0, "y": 58, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 27,
      "type": "logs",
      "title": "Headscale recent logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "x": 0, "y": 59, "w": 24, "h": 10 },
      "targets": [
        { "expr": "{container=\"cloudnet-headscale-1\"}", "refId": "A" }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    }
  ]
}
